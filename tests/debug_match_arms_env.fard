import("../packages/fard_eval/eval") as ev
import("std/list") as list
import("std/record") as rec
import("std/io") as io
import("../packages/fard_parse/parse") as parse
import("std/type") as type

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let env0b = ev.env_set(ev.env_set(ev.env_set(ev.env_empty(), "list", list), "rec", rec), "type", type)
let env1 = list.fold(defs, env0b, fn(acc, d) {
  if d.t == "def_fn" then ev.env_set(acc, d.name, ev.eval(d, acc))
  else acc
})
let match_arms_fn = ev.env_get(env1, "eval_match_arms")
test "has eval_match_arms" { match_arms_fn != null }
let captured_env = match_arms_fn.env
test "eval in captured env" { rec.has(captured_env, "eval") == true }
