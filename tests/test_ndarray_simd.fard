import("../packages/ndarray-simd/main") as nd

let z = nd.zeros([2,3])
let a = nd.from_list([1,2,3,4], [2,2])

test "backend"     { z.backend == "simd" }
test "zeros size"  { nd.size(z) == 6 }
test "shape"       { nd.shape(a) == [2,2] }
test "sum"         { nd.sum(nd.ones([4])) == 4.0 }
test "reshape"     { nd.shape(nd.reshape(a, [1,4])) == [1,4] }
