import("../packages/fard_parse/parse") as parse
import("../packages/fard_eval/eval") as ev
import("std/list") as list
import("std/io") as io

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)

let env0 = ev.env_empty()
let result = list.fold(defs, { env: env0, i: 0, ok: true }, fn(acc, d) {
  if !acc.ok then acc
  else
    let v = if d.t == "def_fn" || d.t == "top_let" then ev.eval(d, acc.env) else null in
    let env2 = if d.t == "def_fn" then ev.env_set(acc.env, d.name, v)
               else if d.t == "top_let" then ev.env_set(acc.env, d.name, v)
               else acc.env in
    { env: env2, i: acc.i + 1, ok: true }
})
result.i
