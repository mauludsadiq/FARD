import("../packages/fard_hm/hm") as hm
import("std/record") as rec

let env = rec.set({}, "x", { t: "scheme", vars: [], ty: { t: "tvar", id: 0 } })
let node = { t: "call", fn: { t: "get_field", obj: { t: "var", name: "x" }, field: "foo" }, args: [] }
let r = hm.infer(node, env, {}, 1)
test "result has ty" { r.ty == r.ty }
