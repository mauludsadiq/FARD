import("../packages/fard_parse/parse") as parse
import("std/list") as list

let defs = parse.parse_program("fn add(x, y) { x + y }\nlet z = 1 + 2")
test "def count" { list.len(defs) == 2 }
test "first is def_fn" { defs[0].t == "def_fn" }
test "fn name" { defs[0].name == "add" }
test "fn params" { defs[0].params[0] == "x" }
test "second is top_let" { defs[1].t == "top_let" }
test "let name" { defs[1].name == "z" }
