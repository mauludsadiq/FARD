import("../packages/fard_parse/parse") as parse
import("std/list") as list
import("std/io") as io

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let eval_def = list.filter(defs, fn(d) { d.t == "def_fn" && d.name == "eval" })[0]
test "found eval" { eval_def.name == "eval" }
test "body is match" { eval_def.body.t == "match_expr" }
list.len(eval_def.body.arms)
