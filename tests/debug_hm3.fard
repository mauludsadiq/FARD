import("../packages/fard_hm/hm") as hm
import("std/record") as rec

let env = {}
let id_fn = {
  t: "node_fn",
  params: ["x"],
  body: { t: "var", name: "x" }
}
let call_id = rec.set(rec.set(rec.set({}, "t", "call"), "fn", id_fn), "args", [{ t: "lit_int", v: 7 }])

let r = hm.infer(call_id, env, {}, 0)
test "call result ty" { r.ty == "int" }
