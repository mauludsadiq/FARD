import("../packages/core-time/main") as time

let epoch = 0

test "format year"    { time.format(epoch, "%Y") == "1970" }
test "field year"     { time.field(epoch, "year") == 1970 }
test "field day"      { time.field(epoch, "day") == 1 }
test "add days"       { time.field(time.add(epoch, "days", 1), "day") == 2 }
test "diff"           { time.diff(86400, 0) == 86400 }
test "days helper"    { time.days(1) == 86400 }
test "hours helper"   { time.hours(1) == 3600 }
test "minutes helper" { time.minutes(1) == 60 }
test "iso8601"        { time.iso8601(epoch) == "1970-01-01T00:00:00Z" }
test "date"           { time.date(epoch) == "1970-01-01" }
test "now positive"   { time.now() > 0 }
