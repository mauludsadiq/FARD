import("../packages/data-excel/main") as xl
import("std/list") as list

let sheet = [[1,2,3],[4,5,6]]
let wb    = xl.workbook({ sheet1: sheet })

test "workbook type"  { wb.t == "workbook" }
test "nrows"          { xl.nrows(sheet) == 2 }
test "ncols"          { xl.ncols(sheet) == 3 }
test "empty ncols"    { xl.ncols([]) == 0 }
