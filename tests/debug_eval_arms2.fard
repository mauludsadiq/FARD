import("../packages/fard_eval/eval") as ev
import("../packages/fard_parse/parse") as parse
import("std/list") as list
import("std/record") as rec
import("std/io") as io
import("std/menv") as menv

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let e = menv.new()
menv.set(e, "list", list)
menv.set(e, "rec", rec)
let dummy = list.fold(defs, null, fn(acc, d) {
  if d.t == "def_fn" then menv.set(e, d.name, ev.eval(d, e)) else null
})

let self_eval = menv.get(e, "eval")
let arms = self_eval.body.arms
test "num arms" { list.len(arms) > 5 }
test "arm0 v" { arms[0].pat_val.v == "lit_int" }
test "arm1 v" { arms[1].pat_val.v == "lit_bool" }
test "arm2 v" { arms[2].pat_val.v == "lit_text" }
test "arm3 v" { arms[3].pat_val.v == "lit_null" }
test "arm4 v" { arms[4].pat_val.v == "var" }
test "arm5 v" { arms[5].pat_val.v == "get_field" }
test "arm6 v" { arms[6].pat_val.v == "index" }
test "arm7 v" { arms[7].pat_val.v == "call" }
test "arm8 v" { arms[8].pat_val.v == "call_builtin" }
test "arm9 v" { arms[9].pat_val.v == "if_node" }
