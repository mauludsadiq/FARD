import("../../packages/video-core/src/rawvid") as rawvid
import("../../packages/video-core/src/rawvid_decode") as rawvid_decode
import("../../packages/video-core/src/frame_sequence_materialize") as frame_sequence_materialize
import("../../packages/image-core/src/color") as color
import("../../packages/image-core/src/raster") as raster
import("../../packages/video-core/src/frame") as frame
import("std/io") as io

let img = raster.make(2, 1, fn(x, y) {
  if x == 0 then color.rgb(255, 0, 0) else color.rgb(0, 255, 0)
})
let fr0 = frame.make(0, 0, 24, img)
let fr1 = frame.make(1, 1, 24, img)
let rv = rawvid.rawvid_bytes(2, 1, 24, 1, [fr0, fr1])
let h = rawvid_decode.header(rv)
let _ = io.make_dir("out/test_frames_dbg2")
frame_sequence_materialize.write_one(rv, h, "out/test_frames_dbg2", 0)
