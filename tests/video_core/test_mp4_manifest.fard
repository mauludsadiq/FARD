import("../../packages/video-core/src/mp4_manifest") as mp4_manifest

let v = { "artifact_type": "video/x-fard-rawvid", "path": "out/test_pattern.fvid" }
let a = { "artifact_type": "audio/wav", "path": "out/tone_440.wav" }

let m = mp4_manifest.make("demo_mp4", v, a)

test "mp4 manifest type" { m.artifact_type == "video/mp4-manifest" }
test "mp4 manifest title" { m.title == "demo_mp4" }
test "mp4 manifest video" { m.video.path == "out/test_pattern.fvid" }
test "mp4 manifest audio" { m.audio.path == "out/tone_440.wav" }
test "mp4 manifest bridge" { m.bridge == "rawvid_wav_to_mp4_manifest" }
