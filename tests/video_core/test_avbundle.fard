import("../../packages/video-core/src/avbundle") as avbundle

let v = { "artifact_type": "video/x-fard-rawvid", "title": "clip" }
let a = { "artifact_type": "audio/wav", "title": "tone" }

let b = avbundle.make("bundle", v, a)

test "avbundle type" { b.artifact_type == "video/x-fard-avbundle" }
test "avbundle title" { b.title == "bundle" }
test "avbundle video" { b.video.artifact_type == "video/x-fard-rawvid" }
test "avbundle audio" { b.audio.artifact_type == "audio/wav" }
