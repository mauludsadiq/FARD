import("../packages/fard_eval/eval") as ev
import("../packages/fard_parse/parse") as parse
import("std/list") as list
import("std/record") as rec
import("std/type") as type
import("std/io") as io

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let env0 = ev.env_set(ev.env_set(ev.env_set(ev.env_empty(), "list", list), "rec", rec), "type", type)
let env1 = list.fold(defs, env0, fn(acc, d) {
  if d.t == "def_fn" then ev.env_set(acc, d.name, ev.eval(d, acc)) else acc
})
let self_eval = ev.env_get(env1, "eval")

let r1 = ev.apply_fn(self_eval, [{ t: "lit_int", v: 3 }, ev.env_empty()])
test "self_eval lit_int" { r1 == 3 }

let self_eval_args = ev.env_get(env1, "eval_args")
let result = ev.apply_fn(self_eval_args, [self_eval, [{ t: "lit_int", v: 3 }], ev.env_empty()])
test "eval_args_type" { type.of(result) == "list" }
