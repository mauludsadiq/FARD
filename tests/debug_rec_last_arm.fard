import("../packages/fard_parse/parse") as parse
import("std/list") as list

let src = "fn f(x) {\n  match x {\n    \"a\" => 1,\n    _ => { t: \"err\", e: \"bad\" }\n  }\n}\nfn g(x) { x + 1 }"
let defs = parse.parse_program(src)
test "two defs" { list.len(defs) == 2 }
test "g name" { defs[1].name == "g" }
