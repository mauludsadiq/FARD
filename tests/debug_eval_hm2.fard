import("std/ast") as ast
import("../packages/fard_lower/lower") as lower
import("../packages/fard_hm/hm") as hm
import("std/list") as list
import("std/record") as rec
import("std/io") as io

let src = io.read_file("packages/fard_eval/eval.fard").ok
let nodes = ast.parse(src)
let fir = list.filter(list.map(nodes, fn(n) { lower.lower(n) }), fn(d) { d.t != "err" })
let r = hm.infer_program(fir)
r
