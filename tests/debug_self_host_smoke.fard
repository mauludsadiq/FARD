import("../packages/fard_parse/parse") as parse
import("../packages/fard_eval/eval") as ev
import("std/list") as list
import("std/record") as rec

let src = "fn double(x) { x + x }\nlet result = double(21)"
let defs = parse.parse_program(src)

let env0 = ev.env_empty()
let closure = ev.eval(defs[0], env0)
let env1 = ev.env_set(env0, "double", closure)
test "double in env" { rec.has(env1, "double") == true }
let result = ev.eval(defs[1], env1)
test "result" { result == 42 }
