import("std/list") as list
import("std/str") as str

let cond = fn(n) { n < 5 }
let body = fn(n) { n + 1 }
let result = while 0 cond body

test "while value" { result.value == 5 }
test "while step count" { list.len(result.steps) == 5 }
test "while step 0 before" { let s = result.steps in s[0].before == 0 }
test "while step 0 after" { let s = result.steps in s[0].after == 1 }
test "while step 4 after" { let s = result.steps in s[4].after == 5 }
test "while chain_hex len" { str.len(result.chain_hex) == 64 }
test "while chain matches last step" { let s = result.steps in result.chain_hex == s[4].chain_hex }

let sum_cond = fn(s) { s.n < 10 }
let sum_body = fn(s) { { n: s.n + 1, sum: s.sum + s.n } }
let sum_init = { n: 0, sum: 0 }
let sum_result = while sum_init sum_cond sum_body
test "while sum" { sum_result.value.sum == 45 }
