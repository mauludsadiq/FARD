import("../packages/fard_eval/eval") as ev
import("../packages/fard_parse/parse") as parse
import("std/list") as list
import("std/record") as rec
import("std/type") as type
import("std/io") as io
import("std/menv") as menv

// Bootstrap layer 1: native eval loads eval.fard
let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let e = menv.new()
menv.set(e, "list", list)
menv.set(e, "rec", rec)
menv.set(e, "type", type)
menv.set(e, "menv", menv)
let dummy = list.fold(defs, null, fn(acc, d) {
  if d.t == "def_fn" then menv.set(e, d.name, ev.eval(d, e)) else null
})
let self_eval = menv.get(e, "eval")

// Layer 2: self_eval evaluates a simple program
let prog_src = "fn add(a, b) { a + b }\nfn mul(a, b) { a * b }"
let prog_defs = parse.parse_program(prog_src)

let e2 = menv.new()
menv.set(e2, "list", list)
menv.set(e2, "rec", rec)
menv.set(e2, "type", type)
menv.set(e2, "menv", menv)

let dummy2 = list.fold(prog_defs, null, fn(acc, d) {
  let fn_val = ev.apply_fn(self_eval, [d, e2]) in
  menv.set(e2, d.name, fn_val)
})

let call_add = { t: "call", fn: { t: "var", name: "add" }, args: [{ t: "lit_int", v: 3 }, { t: "lit_int", v: 4 }] }
let call_mul = { t: "call", fn: { t: "var", name: "mul" }, args: [{ t: "lit_int", v: 3 }, { t: "lit_int", v: 4 }] }

let r_add = ev.apply_fn(self_eval, [call_add, e2])
let r_mul = ev.apply_fn(self_eval, [call_mul, e2])

test "self-hosted add" { r_add == 7 }
test "self-hosted mul" { r_mul == 12 }
