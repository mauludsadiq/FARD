import("../packages/fard_parse/parse") as parse
import("std/list") as list

let src = "fn f(node, env) {\n  match node.t {\n    \"call\" =>\n      let fn_val = 1 in\n      let args2 = 2 in\n      fn_val,\n    \"var\" => 3\n  }\n}"
let defs = parse.parse_program(src)
test "one def" { list.len(defs) == 1 }
test "body is match" { defs[0].body.t == "match_expr" }
test "two arms" { list.len(defs[0].body.arms) == 2 }
