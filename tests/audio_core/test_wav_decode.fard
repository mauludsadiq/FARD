import("../../packages/audio-core/src/wav") as wav
import("../../packages/audio-core/src/pcm") as pcm
import("../../packages/audio-core/src/synth") as synth
import("../../packages/audio-core/src/wav_decode") as wav_decode
import("../../packages/media-core/src/bytes") as media_bytes
import("std/bytes") as stdbytes
import("std/list") as list
import("std/math") as math

// Build a WAV file then decode it
let samples  = synth.sine(440.0, 0.01, 44100)
let pcm_bytes = pcm.encode_pcm_s16le(samples)
let wav_bytes = wav.wav_bytes(44100, 1, pcm_bytes, 16)

let decoded = wav_decode.decode(wav_bytes)
test "decode ok"          { decoded.ok != null }
test "sample_rate"        { decoded.ok.header.sample_rate == 44100 }
test "channels"           { decoded.ok.header.channels == 1 }
test "bits_per_sample"    { decoded.ok.header.bits_per_sample == 16 }
test "sample count"       { list.len(decoded.ok.samples) == list.len(samples) }

// First sample should be near 0 (sine starts at 0)
test "first sample near 0" { math.abs(list.get(decoded.ok.samples, 0)) < 100 }

// Invalid file
let bad = wav_decode.decode(stdbytes.of_list([0,0,0,0,0,0,0,0]))
test "bad file err"       { bad.err != null }
