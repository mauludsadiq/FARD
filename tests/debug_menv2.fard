import("../packages/fard_eval/eval") as ev
import("../packages/fard_parse/parse") as parse
import("std/list") as list
import("std/record") as rec
import("std/type") as type
import("std/io") as io
import("std/menv") as menv

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let e = menv.new()
menv.set(e, "list", list)
menv.set(e, "rec", rec)
menv.set(e, "type", type)
let dummy = list.fold(defs, null, fn(acc, d) {
  if d.t == "def_fn" then menv.set(e, d.name, ev.eval(d, e)) else null
})

let self_eval = menv.get(e, "eval")
let user_env = menv.new()

let lit42 = { t: "lit_int", v: 42 }
let match_fir = self_eval.body
test "body is match" { match_fir.t == "match_expr" }

let eval_env = menv.child(e)
menv.set(eval_env, "expr", lit42)
menv.set(eval_env, "env", user_env)

let arm0 = match_fir.arms[0]
test "arm0 pat" { arm0.pat_val.v == "lit_int" }
let arm0_result = ev.eval(arm0.body, eval_env)
test "arm0 result" { arm0_result == 42 }
