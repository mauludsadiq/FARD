import("../packages/frame-memory/main") as frame
import("../packages/data-csv/main") as csv
import("std/sqlite") as sqlite
import("std/list") as list
import("std/rec") as rec
import("std/str") as str
import("std/cast") as cast

let csv_data = "name,department,salary
Alice,engineering,95000
Bob,marketing,72000
Carol,engineering,110000
Dave,marketing,68000
Eve,engineering,88000"

let df = frame.from_records(csv.parse_csv(csv_data))
let db_path = "/tmp/fard_pipeline_test.db"
let db = sqlite.open(db_path)

// Create table and insert frame data
let _ = sqlite.exec(db, "DROP TABLE IF EXISTS employees")
let _ = sqlite.exec(db, "CREATE TABLE employees (name TEXT, department TEXT, salary REAL)")

let rows = frame.to_records(df)
let _ = list.fold(rows, null, fn(acc, r) {
  sqlite.exec(db, str.concat([
    "INSERT INTO employees VALUES ('", r.name, "', '", r.department, "', ",
    str.from(r.salary), ")"
  ]))
})

// Query back
let eng = sqlite.query(db, "SELECT * FROM employees WHERE department='engineering' ORDER BY salary DESC")
test "eng count" { list.len(eng) == 3 }
test "top eng" { list.get(eng, 0).name == "Carol" }

// Aggregate in SQL
let agg = sqlite.query(db, "SELECT department, COUNT(*) as cnt, AVG(salary) as avg_sal FROM employees GROUP BY department")
test "dept groups" { list.len(agg) == 2 }
