import("../packages/fard_eval/eval") as ev
import("../packages/fard_parse/parse") as parse
import("std/list") as list
import("std/record") as rec
import("std/type") as type
import("std/io") as io

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
let env0 = ev.env_set(ev.env_set(ev.env_set(ev.env_empty(), "list", list), "rec", rec), "type", type)
let env1 = list.fold(defs, env0, fn(acc, d) {
  if d.t == "def_fn" then ev.env_set(acc, d.name, ev.eval(d, acc)) else acc
})
let self_ecb = ev.env_get(env1, "eval_call_builtin")
let self_eval = ev.env_get(env1, "eval")
let arm3 = self_ecb.body.arms[3]

let base = ev.env_set(self_ecb.env, "eval_call_builtin", self_ecb)
let env2 = ev.env_set(ev.env_set(ev.env_set(base, "eval_fn", self_eval), "node", { t: "call_builtin", name: "int.add", args: [] }), "env", ev.env_empty())

let fn_node = rec.get(arm3.body, "fn")
test "fn_node is var" { fn_node.t == "var" }
let fn_val = ev.eval(fn_node, env2)
test "fn_val not null" { fn_val != null }
test "fn_val type" { type.of(fn_val) == "record" }
test "fn_val.t" { fn_val.t == "closure" }

let cb_node = { t: "call_builtin", name: "int.add", args: [{ t: "lit_int", v: 3 }, { t: "lit_int", v: 4 }] }
let env3 = ev.env_set(ev.env_set(ev.env_set(base, "eval_fn", self_eval), "node", cb_node), "env", ev.env_empty())

let self_eval_args = ev.env_get(env1, "eval_args")
let evaled_args = ev.apply_fn(self_eval_args, [self_eval, cb_node.args, ev.env_empty()])
test "evaled_args" { evaled_args[0] == 3 }
test "evaled_args[1]" { evaled_args[1] == 4 }

let result = ev.eval(arm3.body, env3)
test "arm3 result" { result == 7 }
