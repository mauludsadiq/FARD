import("../packages/fard_hm/hm") as hm
import("std/ast") as ast
import("../packages/fard_lower/lower") as lower
import("std/list") as list
import("std/record") as rec

let nodes = ast.parse("match x.t { \"a\" => 1, \"b\" => 2 }")
let fir = lower.lower(nodes[0])
let env = rec.set({}, "x", { t: "scheme", vars: [], ty: { t: "tvar", id: 0 } })
let r = hm.infer(fir, env, {}, 1)
test "match infers int" { r.ty == "int" }

let nodes2 = ast.parse("match x.t { \"a\" => 1, \"b\" => true }")
let fir2 = lower.lower(nodes2[0])
let r2 = hm.infer(fir2, env, {}, 1)
test "match mixed arms fails" { r2.t == "type_error" }
