import("../packages/fard_parse/parse") as parse
import("../packages/fard_eval/eval") as ev
import("std/list") as list
import("std/io") as io

let src = io.read_file("packages/fard_eval/eval.fard").ok
let defs = parse.parse_program(src)
test "parses eval.fard" { list.len(defs) > 0 }

let env0 = ev.env_empty()
let env1 = list.fold(defs, env0, fn(acc, d) {
  if d.t == "def_fn" then
    ev.env_set(acc, d.name, ev.eval(d, acc))
  else if d.t == "top_let" then
    ev.env_set(acc, d.name, ev.eval(d, acc))
  else acc
})

test "env_empty in env" { ev.env_get(env1, "env_empty") != null }
let double_test = ev.apply_fn(ev.env_get(env1, "env_empty"), [])
test "env_empty works" { double_test == {} }
