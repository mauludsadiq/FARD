import("../packages/test-fuzz/main") as fuzz
import("std/str") as str
import("std/list") as list

let c = fuzz.corpus(["hello", "world"])

test "random_string"  { str.len(fuzz.random_string(10)) <= 10 }
test "random_int"     { let v = fuzz.random_int() in v >= -1000000 && v <= 1000000 }
test "random_bool"    { let v = fuzz.random_bool() in v == true || v == false }
test "corpus type"    { c.t == "fuzz-corpus" }
test "add_case"       { list.len(fuzz.add_case(c, "new").items) == 3 }
test "random_list"    { list.len(fuzz.random_list(fuzz.random_int, 5)) <= 5 }
