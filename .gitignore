# Rust build output
target/
Cargo.lock

# Runtime outputs
out/
_out*/
_run*/
receipts/
receipt.json
*.lock.json

# Backup files
*.bak
*.bak_*
*.bak.*
*.tmp
*.swp
*.rs.bk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/settings.json
*.code-workspace

# Spec scratch (keep canonical fixtures)
spec/tmp/*
!spec/tmp/m5_digest_verify_ok.fard
!spec/tmp/m5_digest_verify_err.fard
!spec/tmp/m5_ok_bundle.fard

# Legacy junk patterns (never again)
=
editors/vscode/node_modules/
editors/vscode/package-lock.json
