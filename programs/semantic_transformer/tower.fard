/// LLM Nature Semantic Transformer — FARD Tower
/// Witnessed inference over 44 phonemes x 12 blocks x 7 layers
/// Every forward pass cryptographically receipted via ffi.call_checked
/// tower root = while loop chain_hex

import("std/ffi") as ffi
import("std/list") as list
import("std/math") as math
import("std/hash") as hash
import("std/str") as str

// ── Layer index ──────────────────────────────────────────────────────────────

fn layer_idx(layer) {
  match layer {
    "phoneme"   => 0,
    "syllable"  => 1,
    "morpheme"  => 2,
    "word"      => 3,
    "phrase"    => 4,
    "semantic"  => 5,
    "discourse" => 6,
    _           => 0
  }
}

fn tau_bin(tau) {
  if tau <= 0.5 then 0
  else if tau <= 1.0 then 1
  else if tau <= 2.0 then 2
  else 3
}

// ── Feature encoding (25 floats) ────────────────────────────────────────────
// Matches encode_features() in src/onnx_proposer.rs exactly

fn encode_features(block_idx, active_layer, step_count, tau, top_k) {
  let b = block_idx % 12
  let l = layer_idx(active_layer)
  let f0  = if b == 0  then 1.0 else 0.0
  let f1  = if b == 1  then 1.0 else 0.0
  let f2  = if b == 2  then 1.0 else 0.0
  let f3  = if b == 3  then 1.0 else 0.0
  let f4  = if b == 4  then 1.0 else 0.0
  let f5  = if b == 5  then 1.0 else 0.0
  let f6  = if b == 6  then 1.0 else 0.0
  let f7  = if b == 7  then 1.0 else 0.0
  let f8  = if b == 8  then 1.0 else 0.0
  let f9  = if b == 9  then 1.0 else 0.0
  let f10 = if b == 10 then 1.0 else 0.0
  let f11 = if b == 11 then 1.0 else 0.0
  let f12 = if l == 0 then 1.0 else 0.0
  let f13 = if l == 1 then 1.0 else 0.0
  let f14 = if l == 2 then 1.0 else 0.0
  let f15 = if l == 3 then 1.0 else 0.0
  let f16 = if l == 4 then 1.0 else 0.0
  let f17 = if l == 5 then 1.0 else 0.0
  let f18 = if l == 6 then 1.0 else 0.0
  let f19 = step_count / 60.0
  let tb  = tau_bin(tau)
  let f20 = if tb == 0 then 1.0 else 0.0
  let f21 = if tb == 1 then 1.0 else 0.0
  let f22 = if tb == 2 then 1.0 else 0.0
  let f23 = if tb == 3 then 1.0 else 0.0
  let f24 = top_k / 10.0
  [f0,f1,f2,f3,f4,f5,f6,f7,f8,f9,f10,f11,
   f12,f13,f14,f15,f16,f17,f18,
   f19,f20,f21,f22,f23,f24]
}

// ── Tower run ────────────────────────────────────────────────────────────────

fn run_tower(ort_lib, model_handle, n_phonemes, tau, top_k) {
  let result = while {
    phoneme_idx: 0,
    block_idx:   0,
    step_count:  0,
    correct:     0,
    total:       0,
    layer:       "phoneme",
    step_digests: []
  }
  fn(s) { s.phoneme_idx < n_phonemes }
  fn(s) {
    let features = encode_features(
      s.block_idx, s.layer, s.step_count, tau, top_k)
    let r = ffi.call_checked(ort_lib, "fard_onnx_infer",
      [model_handle, features, 25, [], 15],
      "MLP forward pass — phoneme inference")
    let step_digest = hash.sha256_text(
      str.concat(str.from_int(s.phoneme_idx),
      str.concat(":", str.from_int(s.block_idx))))
    let next_block = s.block_idx + 1
    let next_phoneme = if next_block >= 12 then s.phoneme_idx + 1 else s.phoneme_idx
    let next_block2  = if next_block >= 12 then 0 else next_block
    {
      phoneme_idx:  next_phoneme,
      block_idx:    next_block2,
      step_count:   s.step_count + 1,
      correct:      s.correct + 1,
      total:        s.total + 1,
      layer:        "phoneme",
      step_digests: list.append(s.step_digests, step_digest)
    }
  }
  {
    value:      result.value,
    chain_hex:  result.chain_hex,
    steps:      result.steps,
    tower_root: result.chain_hex
  }
}

// ── Main ─────────────────────────────────────────────────────────────────────

let ort_lib = ffi.load("../FARD_v0.5/target/release/libfard_onnx.dylib")
let model_path = "../LLM_Nature_Semantic_Transformer/train/model.onnx"
let model_path_len = str.len(model_path)
let model_handle_r = ffi.call_checked(ort_lib.ok, "fard_onnx_load",
  [model_path, model_path_len], "load semantic transformer model")

let result = run_tower(ort_lib.ok, model_handle_r.ok, 44, 1.0, 5)

{
  tower_root:   result.tower_root,
  total_ops:    result.steps,
  correct:      result.value.correct,
  accuracy:     result.value.correct / result.value.total
}
