// ── int.to_text ───────────────────────────────────────────────────────────────
fn emit_int_to_text(buf) { emit_cast_text(buf) }

// ── Dispatch table ────────────────────────────────────────────────────────────
// Returns { buf, addrs } where addrs maps dispatch_id -> byte offset in buf

fn emit_all_stdlib(buf) {
  let addrs = array.new() in

  // list module (mod=0)
  let _ = array.push(addrs, { id: id_list_len(),    off: buf_len(buf) }) in let _ = emit_list_len(buf) in
  let _ = array.push(addrs, { id: id_list_get(),    off: buf_len(buf) }) in let _ = emit_list_get(buf) in
  let _ = array.push(addrs, { id: id_list_append(), off: buf_len(buf) }) in let _ = emit_list_append(buf) in
  let _ = array.push(addrs, { id: id_list_tail(),   off: buf_len(buf) }) in let _ = emit_list_tail(buf) in
  let _ = array.push(addrs, { id: id_list_fold(),   off: buf_len(buf) }) in let _ = emit_list_fold(buf) in
  let _ = array.push(addrs, { id: id_list_build(),  off: buf_len(buf) }) in let _ = emit_list_build(buf) in
  let _ = array.push(addrs, { id: id_list_concat(), off: buf_len(buf) }) in let _ = emit_list_concat(buf) in

  // array module (mod=1)
  let _ = array.push(addrs, { id: id_array_len(),     off: buf_len(buf) }) in let _ = emit_array_len(buf) in
  let _ = array.push(addrs, { id: id_array_new(),     off: buf_len(buf) }) in let _ = emit_array_new(buf) in
  let _ = array.push(addrs, { id: id_array_push(),    off: buf_len(buf) }) in let _ = emit_array_push(buf) in
  let _ = array.push(addrs, { id: id_array_get(),     off: buf_len(buf) }) in let _ = emit_array_get(buf) in
  let _ = array.push(addrs, { id: id_array_set(),     off: buf_len(buf) }) in let _ = emit_array_set(buf) in
  let _ = array.push(addrs, { id: id_array_pop(),     off: buf_len(buf) }) in let _ = emit_array_pop(buf) in
  let _ = array.push(addrs, { id: id_array_to_list(), off: buf_len(buf) }) in let _ = emit_array_to_list(buf) in

  // str module (mod=2)
  let _ = array.push(addrs, { id: id_str_len(),        off: buf_len(buf) }) in let _ = emit_str_len(buf) in
  let _ = array.push(addrs, { id: id_str_concat(),     off: buf_len(buf) }) in let _ = emit_str_concat(buf) in
  let _ = array.push(addrs, { id: id_str_lex_tokens(), off: buf_len(buf) }) in let _ = emit_str_lex_tokens(buf) in
  let _ = array.push(addrs, { id: id_str_char_at(),    off: buf_len(buf) }) in let _ = emit_str_char_at(buf) in

  // bytes module (mod=3)
  let _ = array.push(addrs, { id: id_bytes_len(),    off: buf_len(buf) }) in let _ = emit_bytes_len(buf) in
  let _ = array.push(addrs, { id: id_bytes_of_str(), off: buf_len(buf) }) in let _ = emit_bytes_of_str(buf) in
  let _ = array.push(addrs, { id: id_bytes_get(),    off: buf_len(buf) }) in let _ = emit_bytes_get(buf) in
  let _ = array.push(addrs, { id: id_bytes_to_hex(), off: buf_len(buf) }) in let _ = emit_bytes_to_hex(buf) in

  // fs module (mod=4)
  let _ = array.push(addrs, { id: id_fs_read_text(),   off: buf_len(buf) }) in let _ = emit_fs_read_text(buf) in
  let _ = array.push(addrs, { id: id_fs_write_bytes(), off: buf_len(buf) }) in let _ = emit_fs_write_bytes(buf) in

  // cast module (mod=5)
  let _ = array.push(addrs, { id: id_cast_text(), off: buf_len(buf) }) in let _ = emit_cast_text(buf) in

  // int module (mod=6)
  let _ = array.push(addrs, { id: id_int_to_text(), off: buf_len(buf) }) in let _ = emit_int_to_text(buf) in

  { addrs: array.to_list(addrs) }
}

{ emit_all_stdlib: emit_all_stdlib,
  mod_list: mod_list, mod_array: mod_array, mod_str: mod_str,
  mod_bytes: mod_bytes, mod_fs: mod_fs, mod_cast: mod_cast,
  mod_int: mod_int,
  dispatch_id: dispatch_id,
  id_list_len: id_list_len, id_list_get: id_list_get,
  id_list_append: id_list_append, id_list_tail: id_list_tail,
  id_list_fold: id_list_fold, id_list_build: id_list_build,
  id_list_concat: id_list_concat,
  id_array_len: id_array_len, id_array_new: id_array_new,
  id_array_push: id_array_push, id_array_get: id_array_get,
  id_array_set: id_array_set, id_array_pop: id_array_pop,
  id_array_to_list: id_array_to_list,
  id_str_len: id_str_len, id_str_concat: id_str_concat,
  id_str_lex_tokens: id_str_lex_tokens, id_str_char_at: id_str_char_at,
  id_bytes_len: id_bytes_len, id_bytes_of_str: id_bytes_of_str,
  id_bytes_get: id_bytes_get, id_bytes_to_hex: id_bytes_to_hex,
  id_fs_read_text: id_fs_read_text, id_fs_write_bytes: id_fs_write_bytes,
  id_cast_text: id_cast_text, id_int_to_text: id_int_to_text }
