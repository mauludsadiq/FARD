import("std/list") as list
import("std/record") as rec
import("std/type") as type

fn env_empty() { {} }

fn env_get(env, name) { rec.get(env, name) }

fn env_set(env, name, value) { rec.set(env, name, value) }

fn eval_args(eval_fn, args, env) {
  list.map(args, fn(a) { eval_fn(a, env) })
}

fn apply_builtin(name, args) {
  match name {
    "int.add" => args[0] + args[1],
    "int.sub" => args[0] - args[1],
    "int.mul" => args[0] * args[1],
    "int.div" => args[0] / args[1],
    "int.eq" => args[0] == args[1],
    "int.ne" => args[0] != args[1],
    "int.lt" => args[0] < args[1],
    "int.le" => args[0] <= args[1],
    "int.gt" => args[0] > args[1],
    "int.ge" => args[0] >= args[1],
    _ => { t: "err", e: "unsupported_builtin" }
  }
}

fn make_closure(params, body, env) {
  { t: "closure", params: params, body: body, env: env }
}

fn make_named_closure(name, params, body, env) {
  { t: "closure", name: name, params: params, body: body, env: env }
}

fn bind_params(params, args, env) {
  if list.len(params) == 0 then env
  else bind_params(
    list.drop(params, 1),
    list.drop(args, 1),
    rec.set(env, params[0], args[0])
  )
}

fn apply_fn(fn_val, args) {
  match fn_val.t {
    "closure" =>
      let base_env =
        if rec.has(fn_val, "name") then
          env_set(fn_val.env, fn_val.name, fn_val)
        else
          fn_val.env in
      let env2 = bind_params(fn_val.params, args, base_env) in
      eval(fn_val.body, env2),
    _ => { t: "err", e: "not_callable" }
  }
}

fn eval_bool_not(eval_fn, arg, env) {
  let a = eval_fn(arg, env) in
  !a
}

fn eval_bool_and(eval_fn, arg1, arg2, env) {
  let a = eval_fn(arg1, env) in
  if a then eval_fn(arg2, env) else false
}

fn eval_bool_or(eval_fn, arg1, arg2, env) {
  let a = eval_fn(arg1, env) in
  if a then true else eval_fn(arg2, env)
}

fn eval_call_builtin(eval_fn, node, env) {
  match node.name {
    "bool.not" => eval_bool_not(eval_fn, node.args[0], env),
    "bool.and" => eval_bool_and(eval_fn, node.args[0], node.args[1], env),
    "bool.or" => eval_bool_or(eval_fn, node.args[0], node.args[1], env),
    _ => apply_builtin(node.name, eval_args(eval_fn, node.args, env))
  }
}

fn match_pat(pat_val, v) {
  if pat_val.t == "err" then true
  else if pat_val.t == "lit_int" then v == pat_val.v
  else if pat_val.t == "lit_bool" then v == pat_val.v
  else if pat_val.t == "lit_text" then v == pat_val.v
  else true
}

fn eval_match_arms(eval_fn, v, arms, env) {
  if list.len(arms) == 0 then { t: "err", e: "no_matching_arm" }
  else
    let arm = arms[0] in
    if match_pat(arm.pat_val, v) then eval_fn(arm.body, env)
    else eval_match_arms(eval_fn, v, list.drop(arms, 1), env)
}

fn eval(node, env) {
  match node.t {
    "lit_int" => node.v,
    "lit_text" => node.v,
    "lit_bool" => node.v,

    "var" => env_get(env, node.name),

    "call_builtin" => eval_call_builtin(eval, node, env),

    "node_fn" => make_closure(node.params, node.body, env),

    "call" =>
      let fn_node = rec.get(node, "fn") in
      let fn_val = eval(fn_node, env) in
      let args2 = eval_args(eval, node.args, env) in
      if type.of(fn_val) == "func" then list.apply(fn_val, args2)
      else apply_fn(fn_val, args2),

    "let" =>
      let b = node.bindings[0] in
      let v = eval(b.value, env) in
      let env2 = env_set(env, b.name, v) in
      eval(node.body, env2),

    "def_fn" => make_named_closure(node.name, node.params, node.body, env),

    "top_let" => eval(node.value, env),

    "top_import" => null,

    "get_field" => rec.get(eval(node.obj, env), node.field),

    "index" =>
      let obj_val = eval(node.obj, env) in
      let idx_val = eval(node.idx, env) in
      obj_val[idx_val],

    "lit_record" =>
      list.fold(node.fields, {}, fn(acc, f) { rec.set(acc, f.key, eval(f.value, env)) }),

    "lit_list" => list.map(node.items, fn(x) { eval(x, env) }),

    "lit_null" => null,

    "top_let" => eval(node.value, env),

    "top_import" => null,

    "get_field" => rec.get(eval(node.obj, env), node.field),

    "lit_record" =>
      list.fold(node.fields, {}, fn(acc, f) { rec.set(acc, f.key, eval(f.value, env)) }),

    "lit_list" => list.map(node.items, fn(x) { eval(x, env) }),

    "lit_null" => null,

    "match_expr" =>
      let v = eval(node.expr, env) in
      eval_match_arms(eval, v, node.arms, env),

    "if_node" =>
      let cond = eval(rec.get(node, "cond"), env) in
      if cond then eval(rec.get(node, "t_branch"), env)
      else eval(rec.get(node, "f_branch"), env),

    _ => { t: "err", e: "unsupported_eval_node" }
  }
}

fn eval_module(m, env) {
  let env2 = list.fold(m.defs, env, fn(acc, d) {
    let v = eval(d, acc) in
    rec.set(acc, d.name, v)
  }) in
  env_get(env2, m.entry)
}

{
  env_empty: env_empty,
  env_get: env_get,
  env_set: env_set,
  make_closure: make_closure,
  make_named_closure: make_named_closure,
  apply_fn: apply_fn,
  eval: eval,
  eval_module: eval_module
}
