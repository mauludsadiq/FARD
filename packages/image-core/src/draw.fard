import("std/list") as list
import("std/cast") as cast
import("./color") as color
import("./raster") as raster

fn gradient(width, height) {
  raster.make(width, height, fn(x, y) {
    let r = cast.float(x) / cast.float(width) in
    let g = cast.float(y) / cast.float(height) in
    let b = 0.5 in
    color.rgb(cast.int(r * 255.0), cast.int(g * 255.0), cast.int(b * 255.0))
  })
}

export { gradient }
