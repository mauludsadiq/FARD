import("std/list") as list
import("std/math") as math
import("std/cast") as cast
import("./sample") as sample
import("../../media-core/src/bytes") as media_bytes

fn encode_pcm_s16le(samples) {
  let scaled = list.map(samples, fn(s) {
    let clamped = sample.clamp_unit(s) in
    cast.int(math.floor(clamped * 32767.0))
  }) in
  media_bytes.concat_many(list.map(scaled, media_bytes.i16le))
}

export { encode_pcm_s16le }
