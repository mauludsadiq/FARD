import("std/list") as list
import("std/math") as math
import("std/cast") as cast
import("./sample") as sample

fn sine(freq, duration_s, sample_rate) {
  let count = cast.int(math.floor(duration_s * cast.float(sample_rate))) in
  list.map(list.range(0, count), fn(i) {
    let t = sample.time_at(i, sample_rate) in
    math.sin(2.0 * math.pi * freq * t)
  })
}

export { sine }
