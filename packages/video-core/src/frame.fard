import("../../image-core/src/draw") as draw

fn make(index, pts_num, pts_den, raster) {
  {
    "index": index,
    "pts_num": pts_num,
    "pts_den": pts_den,
    "raster": raster
  }
}

fn test_pattern(width, height, index) {
  let raster = draw.gradient(width, height) in
  make(index, index, 1, raster)
}

export { make, test_pattern }
